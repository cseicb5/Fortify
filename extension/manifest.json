{
  "manifest_version": 3,
  "name": "Fortify URL Checker",
  "version": "1.1",
  "description": "Blocks banned sites and checks current site for phishing signs and DNS info.",
  
  "permissions": [
    "tabs",
    "webNavigation",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>",
    "https://dns.google/"
  ],
  
  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "web_accessible_resources": [
    {
      "resources": ["blocked.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
