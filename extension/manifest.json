{
  "manifest_version": 2,
  "name": "Fortify URL Checker",
  "version": "1.1",
  "description": "Blocks banned sites and checks current site for phishing signs and DNS info.",
  
  "permissions": [
    "tabs",
    "webNavigation",
    "storage",
    "<all_urls>",
    "https://dns.google/" 
  ],
  
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png" 
  },

  "web_accessible_resources": [
    "blocked.html"
  ],

  "icons": {
    "48": "icon.png"
  }
}